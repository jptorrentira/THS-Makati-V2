                      <KeepTogether>true</KeepTogether>
                      <Paragraphs>
                        <Paragraph>
                          <TextRuns>
                            <TextRun>
                              <Value>=( Fields!TripCountServed.Value / (Fields!TripCountApproved.Value - Fields!TripCountCancelled.Value) ) * 100</Value>

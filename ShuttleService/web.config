<?xml version="1.0" encoding="utf-8"?>
<configuration>

  <system.webServer>
    <!-- REMOVE IIS SERVER HEADER -->
    <security>
      <requestFiltering removeServerHeader="true" />
    </security>

    <!-- REMOVE POWERED-BY -->
    <httpProtocol>
      <customHeaders>
        <remove name="X-Powered-By" />
      </customHeaders>
    </httpProtocol>
  </system.webServer>

  <!-- DISABLE ASP.NET VERSION HEADERS -->
  <system.web>
    <httpRuntime enableVersionHeader="false" />
  </system.web>

</configuration>

    <DataSet Name="ShuttlePassengers">
      <Query>
        <DataSourceName>ShuttleDS</DataSourceName>
        <CommandText>SELECT
ROW_NUMBER() OVER(ORDER BY ShuttlePassengers.FirstName ASC) as [RowNum],
  ShuttlePassengers.Id AS [ShuttlePassengers Id]
  ,ShuttlePassengers.ServiceDateTimeStamp
  ,ShuttlePassengers.TransactionId
  ,ShuttlePassengers.ServiceDate
  ,ShuttlePassengers.ShuttleId
  ,ShuttlePassengers.PassengerTypeId
  ,ShuttlePassengers.EmployeeNo
  ,ShuttlePassengers.CompanyListId
  ,ShuttlePassengers.CompanyOther
  ,ShuttlePassengers.ChargingCompanyId
  ,ShuttlePassengers.ChargingDepartmentId
  ,ShuttlePassengers.Name
  ,ShuttlePassengers.FirstName
  ,ShuttlePassengers.MiddleName
  ,ShuttlePassengers.LastName
  ,ShuttlePassengers.[Position]
  ,ShuttlePassengers.Purpose
  ,ShuttlePassengers.Remarks
  ,ShuttlePassengers.TripTypeId
  ,ShuttlePassengers.TripTime
  ,ShuttlePassengers.Breakfast
  ,ShuttlePassengers.AmSnack
  ,ShuttlePassengers.PmSnack
  ,ShuttlePassengers.Lunch
  ,ShuttlePassengers.Dinner
  ,ShuttlePassengers.LodgingFrom
  ,ShuttlePassengers.LodgingTo
  ,ShuttlePassengers.EncodedBy
  ,ShuttlePassengers.LastModifiedBy
  ,ShuttlePassengers.EncodeDate
  ,ShuttlePassengers.ModifyDate
  ,ShuttlePassengers.SubmitDate
  ,ShuttlePassengers.ContactNo
  ,ShuttlePassengers.Status
  ,ShuttlePassengers.InitialApproverEmployeeNo
  ,ShuttlePassengers.ApprovedBy
  ,ShuttlePassengers.ApprovedDatetime
  ,ShuttlePassengers.EmployeeId
  ,ShuttlePassengers.CancelReason
  ,ShuttlePassengers.CancelledBy
  ,ShuttlePassengers.CancelledDatetime
  ,ShuttlePassengers.RemovedBy
  ,ShuttlePassengers.RemovedDatetime
  ,ShuttlePassengers.RemovedRemarks
  ,ShuttlePassengers.ReservedBy
  ,ShuttlePassengers.ReservedDatetime
  ,ShuttlePassengers.Gender
  ,ShuttlePassengers.Nationality
  ,ChargingCompanys.Id AS [ChargingCompanys Id]
  ,ChargingCompanys.CompanyName
  ,Trip.Id AS [Trip Id]
  ,Trip.TripControlNo
FROM
  ShuttlePassengers
  INNER JOIN ChargingCompanys
    ON ShuttlePassengers.ChargingCompanyId = ChargingCompanys.Id
  INNER JOIN Trip
    ON ShuttlePassengers.ShuttleId = Trip.Id</CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>

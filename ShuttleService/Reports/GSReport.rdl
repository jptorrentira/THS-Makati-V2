  <DataSets>
    <DataSet Name="Trips">
      <Query>
        <DataSourceName>ShuttleDS</DataSourceName>
        <CommandText>SELECT
  Trip.Id AS [Trip Id]
  ,Trip.TripControlNo
  ,Trip.ServiceDateTimeStamp
  ,Trip.ServiceStartDate
  ,Trip.ServiceEndDate
  ,Trip.VehicleListId
  ,Trip.Capacity AS [Trip Capacity]
  ,Trip.RemainingCapacity
  ,Trip.DriverId
  ,Trip.Status AS [Trip Status]
  ,Trip.ReservationTypeId
  ,Trip.Remarks
  ,Trip.EncodedBy AS [Trip EncodedBy]
  ,Trip.LastModifiedBy AS [Trip LastModifiedBy]
  ,Trip.EncodeDate AS [Trip EncodeDate]
  ,Trip.ModifyDate AS [Trip ModifyDate]
  ,Trip.RemainingCapacityPM
  ,Trip.CancelReason
  ,Trip.CancelledBy
  ,Trip.CancelledDatetime
  ,VehicleLists.Id AS [VehicleLists Id]
  ,VehicleLists.Model
  ,VehicleLists.PlateNumber
  ,VehicleLists.Capacity AS [VehicleLists Capacity]
  ,VehicleLists.CodingDay
  ,VehicleLists.Status AS [VehicleLists Status]
  ,Drivers.Id AS [Drivers Id]
  ,Drivers.FirstName
  ,Drivers.LastName
  ,Drivers.Birthday
  ,Drivers.License_Restriction
  ,Drivers.License_Expiry
  ,Drivers.Status AS [Drivers Status]
  ,Drivers.MobileNumber
  ,Drivers.EncodedBy AS [Drivers EncodedBy]
  ,Drivers.LastModifiedBy AS [Drivers LastModifiedBy]
  ,Drivers.EncodeDate AS [Drivers EncodeDate]
  ,Drivers.ModifyDate AS [Drivers ModifyDate]
  ,Drivers.CivilStatus
  ,Trip.EmailBy
  ,Trip.EmailDatetime
  ,Trip.EmailStatus
FROM
  Trip
  LEFT OUTER JOIN VehicleLists
    ON Trip.VehicleListId = VehicleLists.Id
  INNER JOIN Drivers
    ON Trip.DriverId = Drivers.Id</CommandText>
        <rd:DesignerState>
          <QueryDefinition xmlns="http://schemas.microsoft.com/ReportingServices/QueryDefinition/Relational">
            <AutoJoin>False</AutoJoin>

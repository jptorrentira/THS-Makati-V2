    <DataSet Name="ShuttlePassengersPM">
      <Query>
        <DataSourceName>ShuttleDS</DataSourceName>
        <CommandText>SELECT
ROW_NUMBER() OVER(ORDER BY ShuttlePassengers.FirstName ASC) as [RowNum],
  ShuttlePassengers.Id AS [ShuttlePassengers Id]
  ,ShuttlePassengers.ServiceDateTimeStamp AS [ShuttlePassengers ServiceDateTimeStamp]
  ,ShuttlePassengers.TransactionId
  ,ShuttlePassengers.ServiceDate
  ,ShuttlePassengers.ShuttleId
  ,ShuttlePassengers.PassengerTypeId
  ,ShuttlePassengers.EmployeeNo
  ,ShuttlePassengers.CompanyListId
  ,ShuttlePassengers.CompanyOther
  ,ShuttlePassengers.ChargingCompanyId
  ,ShuttlePassengers.ChargingDepartmentId
  ,ShuttlePassengers.Name
  ,ShuttlePassengers.FirstName
  ,ShuttlePassengers.MiddleName
  ,ShuttlePassengers.LastName
  ,ShuttlePassengers.[Position]
  ,ShuttlePassengers.Purpose
  ,ShuttlePassengers.Remarks AS [ShuttlePassengers Remarks]
  ,ShuttlePassengers.TripTypeId
  ,ShuttlePassengers.TripTime
  ,ShuttlePassengers.Breakfast
  ,ShuttlePassengers.AmSnack
  ,ShuttlePassengers.PmSnack
  ,ShuttlePassengers.Lunch
  ,ShuttlePassengers.Dinner
  ,ShuttlePassengers.LodgingFrom
  ,ShuttlePassengers.LodgingTo
  ,ShuttlePassengers.EncodedBy AS [ShuttlePassengers EncodedBy]
  ,ShuttlePassengers.LastModifiedBy AS [ShuttlePassengers LastModifiedBy]
  ,ShuttlePassengers.EncodeDate AS [ShuttlePassengers EncodeDate]
  ,ShuttlePassengers.ModifyDate AS [ShuttlePassengers ModifyDate]
  ,ShuttlePassengers.SubmitDate
  ,ShuttlePassengers.ContactNo
  ,ShuttlePassengers.Status AS [ShuttlePassengers Status]
  ,ShuttlePassengers.InitialApproverEmployeeNo
  ,ShuttlePassengers.ApprovedBy
  ,ShuttlePassengers.ApprovedDatetime
  ,ShuttlePassengers.EmployeeId
  ,ShuttlePassengers.CancelReason AS [ShuttlePassengers CancelReason]
  ,ShuttlePassengers.CancelledBy AS [ShuttlePassengers CancelledBy]
  ,ShuttlePassengers.CancelledDatetime AS [ShuttlePassengers CancelledDatetime]
  ,Trip.Id AS [Trip Id]
  ,Trip.TripControlNo
  ,Trip.ServiceDateTimeStamp AS [Trip ServiceDateTimeStamp]
  ,Trip.ServiceStartDate
  ,Trip.ServiceEndDate
  ,Trip.VehicleListId
  ,Trip.Capacity
  ,Trip.RemainingCapacity
  ,Trip.DriverId
  ,Trip.Status AS [Trip Status]
  ,Trip.ReservationTypeId
  ,Trip.Remarks AS [Trip Remarks]
  ,Trip.EncodedBy AS [Trip EncodedBy]
  ,Trip.LastModifiedBy AS [Trip LastModifiedBy]
  ,Trip.EncodeDate AS [Trip EncodeDate]
  ,Trip.ModifyDate AS [Trip ModifyDate]
  ,Trip.RemainingCapacityPM
  ,Trip.CancelReason AS [Trip CancelReason]
  ,Trip.CancelledBy AS [Trip CancelledBy]
  ,Trip.CancelledDatetime AS [Trip CancelledDatetime]
  ,ShuttlePassengers.RemovedBy
  ,ShuttlePassengers.RemovedDatetime
  ,ShuttlePassengers.RemovedRemarks
  ,ShuttlePassengers.ReservedBy
  ,ShuttlePassengers.ReservedDatetime
FROM
  ShuttlePassengers
  LEFT OUTER JOIN Trip
    ON ShuttlePassengers.ShuttleId = Trip.Id</CommandText>
      </Query>

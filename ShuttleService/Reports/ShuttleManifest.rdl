              <ColumnExpression ColumnOwner="Drivers" ColumnName="CivilStatus" />
            </SelectedColumns>
            <Joins>
              <Join Type="CROSS JOIN" ColumnOwner="Trip" />
              <Join Type="LEFT OUTER JOIN" ColumnOwner="VehicleLists">
                <On>
                  <From ColumnOwner="Trip" ColumnName="VehicleListId" />
                  <To ColumnOwner="VehicleLists" ColumnName="Id" />
                </On>
              </Join>
              <Join Type="INNER JOIN" ColumnOwner="Drivers">
                <On>
                  <From ColumnOwner="Trip" ColumnName="DriverId" />
                  <To ColumnOwner="Drivers" ColumnName="Id" />
                </On>
              </Join>
            </Joins>
          </QueryDefinition>
        </rd:DesignerState>
      </Query>

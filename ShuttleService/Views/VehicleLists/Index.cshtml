
@{
    ViewData["Title"] = "Vehicle List";
}

<style>
    .select2-container {
        z-index: 99999 !important;
    }
</style>
<div class="wrapper-content row">
    <div class="col-md-10 pull-left">
        <h4>Vehicle List Maintenance</h4>
    </div>
</div>


<div class="row">
    <div class=" col-sm-12">
        <a href='javascript:void(0);' onClick='Add()' class='btn btn-sm btn-success'> Add Vehicle </a>
    </div>
    <div class=" col-sm-12">
        <table id="data_table" class="table table-striped table-bordered table-hover text-center table100"></table>
    </div>
</div>

<div class="modal fade" role="dialog" id="modal-edit" style="z-index: 9990!important;" data-backdrop="static" data-keyboard="false">
    <div class="modal-dialog modal-md" role="document">

        <div class="modal-content">
            <div class="modal-header">
                <h3>Vehicle Information</h3>
            </div>
            <form id="formData">
                <div class="modal-body form-horizontal">

                    <div class="row">
                        <div class="form-group">
                            <div class="col-sm-4">
                                <label class="control-label"> Model Name </label>
                            </div>
                            <div class="col-sm-8">
                                <input class="form-control input-sm hidden" disabled id="Id" name="Id" />
                                <input class="form-control input-sm " id="Model" name="Model" />
                            </div>
                        </div>
                    </div>
                    <div class="row">
                        <div class="form-group">
                            <div class="col-sm-4">
                                <label class="control-label"> Plate Number</label>
                            </div>
                            <div class="col-sm-8">
                                <input class="form-control input-sm " id="PlateNumber" name="PlateNumber" />
                            </div>
                        </div>
                    </div>
                    <div class="row">
                        <div class="form-group">
                            <div class="col-sm-4">
                                <label class="control-label"> Capacity </label>
                            </div>
                            <div class="col-sm-8">
                                <input class="form-control input-sm " id="Capacity" name="Capacity" onkeypress="return isNumber(event)" />
                            </div>
                        </div>
                    </div>

                    <div class="row">
                        <div class="form-group">
                            <div class="col-sm-4">
                                <label class="control-label"> Coding </label>
                            </div>
                            <div class="col-sm-8">
                                <select name="CodingDay" id="CodingDay" style="z-index: 99999!important;" class="form-control">
                                    <option disabled selected>--- SELECT ---</option>
                                    <option value="1">Monday</option>
                                    <option value="2">Tuesday</option>
                                    <option value="3">Wednesday</option>
                                    <option value="4">Thursday</option>
                                    <option value="5">Friday</option>
                                </select>
                            </div>
                        </div>
                    </div>
                    <div class="row">
                        <div class="form-group">
                            <div class="col-sm-4">
                                <label class="control-label"> Company Group</label>
                            </div>
                            <div class="col-md-8">
                                <select class="form-control" id="CompanyGroupId" name="CompanyGroupId" asp-items="ViewBag.CompanyGroupList">
                                    <option value="">--- SELECT ---</option>
                                </select>
                            </div>
                        </div>
                    </div>
                    <div class="row" id="locationField" style="display: none;">
                        <div class="form-group">
                            <div class="col-sm-4">
                                <label class="control-label"> Location/s </label>
                            </div>
                            <div class="col-md-8">
                                <select class="form-control select2simple" id="LocationIds" name="LocationIds" multiple asp-items="ViewBag.LocationListId">
                                </select>
                            </div>
                        </div>
                    </div>
                    <div class="row">
                        <div class="form-group">
                            <div class="col-sm-4">
                                <label class="control-label"> Status </label>
                            </div>
                            <div class="col-sm-8">
                                <select name="Status" id="Status" style="z-index: 99999!important;" class="form-control">
                                    <option disabled selected>--- SELECT ---</option>
                                    <option value="1">Active</option>
                                    <option value="0">Inactive</option>
                                </select>
                            </div>
                        </div>
                    </div>



                </div>
            </form>
            <div class="modal-footer">
                <div class="btn-group pull-right">
                    <button class="ladda-button btn btn-primary" onClick="SaveUpdate();" id="btnSave" type="button" data-style="expand-left">Save</button>
                    <button class="btn btn-danger" type="button" data-dismiss="modal">Close</button>
                </div>
            </div>
        </div><!-- /.modal-content -->
    </div><!-- /.modal-dialog -->
</div><!-- /.modal -->

<div class="modal fade" role="dialog" id="modal-maintenance" style="z-index: 9990!important;" data-backdrop="static" data-keyboard="false">
    <div class="modal-dialog modal-lg" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h3>Maintenance Information - <label id="vehicleName"></label></h3>
            </div>
            <div class="modal-body form-horizontal">
                <form id="formMaintenance">
                    <div class="row">
                        <div class=" col-sm-12">
                            <input class="form-control input-sm hidden" disabled id="vehicleId" value="-1" name="vehicleId" />
                            <table id="data_table_maintenance" class="table table-striped table-bordered table-hover text-center table100"></table>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-sm-2"></div>
                        <div class="col-sm-8">
                            <div class="row">
                                <div class="form-group">
                                    <label style="color:red">Add Maintenance</label>
                                </div>
                            </div>
                            <div class="row">
                                <div class="form-group">
                                    <div class="col-sm-4">
                                        <label class="control-label">From</label>
                                    </div>
                                    <div class="col-md-8">
                                        @*<input class="form-control input-sm datepicker" onchange="ReloadCalendarPicker();" id="MaintenanceFrom" name="MaintenanceFrom" />*@
                                        <input class="form-control input-sm datepicker" onchange="ReloadCalendarPicker();" id="MaintenanceFrom" name="MaintenanceFrom" />
                                    </div>
                                </div>
                            </div>
                            <div class="row">
                                <div class="form-group">
                                    <div class="col-sm-4">
                                        <label class="control-label">To</label>
                                    </div>
                                    <div class="col-md-8">
                                        <input class="form-control input-sm datepicker" id="MaintenanceTo" name="MaintenanceTo" />
                                    </div>
                                </div>
                            </div>
                            @*<div class="row">
            <div class="form-group">
                <div class="col-sm-4">
                    <label class="control-label">Valid To</label>
                </div>
                <div class="col-md-8">
                    <input class="form-control input-sm datepicker" disabled id="MaintenanceTo" name="MaintenanceTo" />
                </div>
            </div>
        </div>*@
                            <div class="row">
                                <div class="form-group">
                                    <div class="col-sm-4">
                                        <label class="control-label">Remarks</label>
                                    </div>
                                    <div class="col-md-8">
                                        <input class="form-control input-sm" id="MaintenanceRemarks" name="MaintenanceRemarks" />
                                    </div>
                                </div>
                            </div>
                            <div class="row">
                                <div class="form-group">
                                    <div class="col-sm-4">
                                    </div>
                                    <div class="col-md-8">
                                        <button class="btn btn-success" type="button" onclick="SaveMaintenance();">Save</button>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <div class="btn-group pull-right">
                    <button class="btn btn-danger" type="button" data-dismiss="modal">Close</button>
                </div>
            </div>
        </div><!-- /.modal-content -->
    </div><!-- /.modal-dialog -->
</div><!-- /.modal -->


@section Scripts {
    <script src="https://repo.aunasin.com/assets/tths/vendors/datatables.net/js/jquery.dataTables.min.js"></script>
    <script src="https://repo.aunasin.com/assets/tths/vendors/datatables.net-bs/js/dataTables.bootstrap.min.js"></script>
    <script src="https://repo.aunasin.com/assets/tths/vendors/datatables.net/js/dataTables.select.min.js"></script>
}

<script>
    $(document).ready(function() {
        // Initial check
        checkCompanyGroup();

        // Trigger check when CompanyGroupId changes
        $("#CompanyGroupId").on("change", function() {
            checkCompanyGroup();
        });
        $(".select2simple").select2();
    });

    var reloader = 0;
    var table1 = $('#data_table').DataTable({
            "processing": false,
            "serverSide": true,
            "autoWidth": false,
            "searching": true,
            "scrollX": true,
            "bLengthChange": false,
            "ajax": {
                "url": "@Url.Content("~/vehiclelists/ShowVehicleLists")",
                "type": "POST"
            },
        "columns": [

                { "data": "id", title: "ID", width: "5%", align: "center", visible: false, orderable: false },
                { "data": "action", title: "Action", orderable: false },
                { "data": "model", title: "Model", orderable: false },
                { "data": "plateNumber", title: "Plate Number", orderable: false },
                { "data": "capacity", title: "Capacity", orderable: false },
                { "data": "coding", title: "Coding", visible: false, orderable: false },
                { "data": "codingDayName", title: "Coding", orderable: false },
                { "data": "companyGroupName", title: "Company Group", orderable: false },
                { "data": "status", title: "Status", orderable: false }
            ]
            ,
            'select': {
                'style': 'single'
            },
            'columnDefs': [
                {
                    "targets": "_all", // your case first column
                    "className": "text-center",
                }],
            "order": [[2, "asc"]],
            "initComplete": function (settings, json) {
                if (reloader == 0) {
                    reloader = 1;
                    var myVar = setInterval(function () {
                        $('#data_table').DataTable().columns.adjust().draw();
                        clearInterval(myVar);
                    }, 500);

                }
            }
    });
    var table1 = $('#data_table_maintenance').DataTable({
            "processing": false,
            "serverSide": true,
            "autoWidth": false,
            "searching": true,
            "scrollX": true,
            "bLengthChange": false,
            "ajax": {
                "url": "@Url.Content("~/vehiclelists/ShowMaintenanceLists")",
                "type": "POST",
                "data": function (d) {
                    d.vehicleId = $("#vehicleId").val();
                }
            },
        "columns": [
                { "data": "id", title: "ID", width: "5%", align: "center", visible: false, orderable: false },
                { "data": "controlNo", title: "ControlNo", orderable: false },
                { "data": "from", title: "From", orderable: false },
                { "data": "to", title: "To", orderable: false },
                { "data": "remarks", title: "Remarks", orderable: false },
                { "data": "processedBy", title: "ProcessedBy", visible: false, orderable: false },
            ]
            ,
            'select': {
                'style': 'single'
            },
            'columnDefs': [
                {
                    "targets": "_all", // your case first column
                    "className": "text-center",
                }],

            "initComplete": function (settings, json) {
                if (reloader == 0) {
                    reloader = 1;
                    var myVar = setInterval(function () {
                        $('#data_table').DataTable().columns.adjust().draw();
                        clearInterval(myVar);
                    }, 500);

                }
            }
        });

    function Add() {
        $('#formData').trigger("reset");
        $("#modal-edit").modal("show");
        $("#CompanyGroupId").val(null);
        checkCompanyGroup();
    }


    function Edit(id) {

            $("#VehicleId").val("");
            $.ajax({
                    type: "POST",
                    url: "@Url.Content("~/vehiclelists/updateList")?id=" + id,

                    //"contentType": "application/json; charset=utf-8",
                    dataType: "JSON",
                    success: function (data, textStatus, jqXHR) {
                    console.log(data);
                        if (data.success == 1) {

                            $("#Model").val(data['userData'][0].model);
                            $("#PlateNumber").val(data['userData'][0].plateNumber);
                            $("#Capacity").val(data['userData'][0].capacity);
                            $("#CodingDay").val(data['userData'][0].coding).trigger("change");
                            $("#Status").val(data['userData'][0].status).trigger("change");
                            $("#CompanyGroupId").val(data['userData'][0].companyGroup).trigger("change");
                            $("#Id").val(data['userData'][0].vehicleId);

                            if (data['userData'][0].locationIds && data['userData'][0].locationIds.length > 0) {
                                $("#LocationIds").val(data['userData'][0].locationIds).trigger('change');
                            } 
                            else {
                                $("#LocationIds").val(null).trigger('change');
                            }

                            $("#modal-edit").modal("show");

                        } else {
                            swalAlertOnly("Error", data.message, "error");
                        }
                    }
                });
    }

    function checkCompanyGroup() {
        var group = $("#CompanyGroupId option:selected").text();
        if (group === "UPDI") {
            $("#locationField").show();
        } else {
            $("#locationField").hide();
            $("#LocationIds").val(null).trigger("change"); // clear selection
        }
    };

    function SaveUpdate() {
        var isUPDI =  $("#CompanyGroupId option:selected").text() === "UPDI";
        var selectedLocations = $("#LocationIds").val();
        if ($("#Model").val() == '' || $("#PlateNumber").val() == '' || $("#Capacity").val() == '' || $("#CodingDay").val() == '' || $("#CompanyGroupId").val() == '' ) {

            swalAlertOnly("Error", "Please complete all details.", "error");
        }
        else if (isUPDI && (!selectedLocations || selectedLocations.length === 0)){
            swalAlertOnly("Error", "Please complete all details.", "error");
        }
        else {
            swal({
                title: "Are you sure?",
                text: "This will update the details for this vehicle",
                type: "warning",
                showCancelButton: true,
                confirmButtonColor: "#DD6B55",
                confirmButtonText: "Yes, Save it!",
                closeOnConfirm: false
            }, function () {

                SubmitForm();

            });
        }

    }


    function SubmitForm() {
        $("#loading").modal("show");

            $.ajax({
                type: "POST",
                url: "@Url.Content("~/vehiclelists/saveUpdate/")" + $("#Id").val(),
                data: $("#formData").serialize() + "&id=" + $("#Id").val(),
                    //"contentType": "application/json; charset=utf-8",
                    dataType: "JSON",
                    success: function (data, textStatus, jqXHR) {
                        //console.log(data);
                        if (data.success == 1) {
                            $('#data_table').DataTable().clear().draw();
                            $('#data_table').DataTable().ajax.reload();
                            $("#modal-edit").modal("hide");
                            swalAlertOnly("Success", data.message, "success");
                        } else {
                            swalAlertOnly("Error", data.message, "error");
                        }
                        $("#loading").modal("hide");
                    }
        });


    }

    function Maintenance(id, vehname) {
        $("#MaintenanceFrom").val("").trigger("change");
        $("#MaintenanceTo").val("").trigger("change");
        ReloadCalendarPicker();
        $("#MaintenanceRemarks").val("").trigger("change");
        $("#vehicleName").text(vehname);
        $("#vehicleId").val(id);
        $('#data_table_maintenance').DataTable().ajax.reload();
        var myVar = setInterval(function () {
            $('#data_table_maintenance').DataTable().columns.adjust().draw();
            clearInterval(myVar);
        }, 500);
        $("#modal-maintenance").modal("show");
    }

    $('.datepicker').datepicker({
        keyboardNavigation: false,
        forceParse: false,
        autoclose: true,
        todayHighlight: true
    });

    $('#MaintenanceFrom').datepicker({
        keyboardNavigation: false,
        forceParse: false,
        autoclose: true,
        todayHighlight: true
    });

    function ReloadCalendarPicker() {

        if ($('#MaintenanceFrom').val() == "") {

            $('#MaintenanceTo').val("");
            $('#MaintenanceTo').attr("disabled");

        } else {
            $('#MaintenanceTo').val("");
            $('#MaintenanceTo').removeAttr("disabled");
            $('#MaintenanceTo').datepicker("remove").datepicker({
                keyboardNavigation: false,
                forceParse: false,
                autoclose: true,
                todayHighlight: false,
                startDate: $('#MaintenanceFrom').val()
            });
            $("#MaintenanceTo").datepicker("option", "startDate", $('#MaintenanceFrom').val());
        }


    }

    function SaveMaintenance() {

        if ($("#MaintenanceFrom").val() == '' || $("#MaintenanceTo").val() == '' || $("#MaintenanceRemarks").val() == '' || $("#vehicleId").val() < 0) {

            swalAlertOnly("Error", "Please complete all details.", "error");
        }
        else {
            swal({
                title: "Are you sure?",
                text: "This will add the details for this vehicle's maintenance history",
                type: "warning",
                showCancelButton: true,
                confirmButtonColor: "#DD6B55",
                confirmButtonText: "Yes, Save it!",
                closeOnConfirm: false
            }, function () {

                GoSaveMaintenance($("#vehicleId").val());

            });
        }

    }

    function GoSaveMaintenance(id) {

        $.ajax({
                    type: "POST",
                    url: "@Url.Content("~/vehiclelists/createMaintenance")",
                    data: $("#formMaintenance").serialize() + "&id=" + id,
                    dataType: "JSON",
                    success: function (data, textStatus, jqXHR) {
                    console.log(data);
                        if (data.success == 1) {

                            $('#data_table_maintenance').DataTable().ajax.reload();
                            var myVar = setInterval(function () {
                                $('#data_table_maintenance').DataTable().columns.adjust().draw();
                                clearInterval(myVar);
                            }, 500);

                            $("#MaintenanceFrom").val('').trigger('change');
                            $("#MaintenanceTo").val('').trigger('change');
                            $("#MaintenanceRemarks").val('').trigger('change');

                            swalAlertOnly("Success", data.message, "success");
                        } else {
                            swalAlertOnly("Error", data.message, "error");
                        }
                    }
                });
    }
</script>

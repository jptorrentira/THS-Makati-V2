     function ViewTrip() {
        $('#tableSelectTrip').DataTable().clear().draw();
        $('#tableSelectTrip').DataTable().ajax.reload();
        $("#ModalSelectTrip").modal("show");
        setTimeout(function () {
            $('#tableSelectTrip').DataTable().columns.adjust().responsive.recalc();
        }, 500);
    }

    function OpenThisTrip(id) {
        $("#ModalSelectTrip").modal("hide");
        $("#loading").modal('show');
                    $.ajax({
                            type: "POST",
                            url: "@Url.Content("~/trips/checkTrip")",
                            data: "tripId=" + id,
                            //"contentType": "application/json; charset=utf-8",
                            dataType: "JSON",
                            success: function (data, textStatus, jqXHR) {

                                $("#loading").modal("hide");

                                $("#lblVehicle").html(data['vehicleName'][0].model + " / " + data['vehicleName'][0].plateNumber);
                                $("#lblCapacity").text(data['data'].capacity);
                                $("#lblRemaining").text(data['data'].remainingCapacity);
                                $("#lblRemainingPM").text(data['data'].remainingCapacityPM);
                                $("#lblDriver").text(data['driverName'].firstName + " " + data['driverName'].lastName);
                                $("#TripId").val(id);
                                $("#lblTrip").text(data['data'].tripControlNo);
                                $(".TripLookup").removeClass("hidden");
                                $("#ReserveBtn").removeClass("hidden");

                                $(".reservedDiv").removeClass("hidden");

                                $('#tableMorning').DataTable().ajax.reload();
                                $('#tableAfternoon').DataTable().ajax.reload();

                                setTimeout(function () {
                                    $('#tableMorning').DataTable().columns.adjust().responsive.recalc();
                                    $('#tableAfternoon').DataTable().columns.adjust().responsive.recalc();
                                    $('#tableMorningAvailable').DataTable().columns.adjust().responsive.recalc();
                                    $('#tableAfternoonAvailable').DataTable().columns.adjust().responsive.recalc();
                                    $("#loading").modal("hide");
                                }, 500);
                            }
                    });
    }


</script>





@if (_dtrip != null)
{
    if (_dtrip.Id > 0)
    {   
        <script>
            OpenThisTrip(@_dtrip.Id);
            //$("#TripId").val(`@_dtrip.Id`);
            //$(".TripLookup").removeClass("hidden");

            $('#tableMorning').DataTable().ajax.reload();
            $('#tableAfternoon').DataTable().ajax.reload();

            setTimeout(function () {
                $('#tableMorning').DataTable().columns.adjust().responsive.recalc();
                $('#tableAfternoon').DataTable().columns.adjust().responsive.recalc();
                $('#tableMorningAvailable').DataTable().columns.adjust().responsive.recalc();
                $('#tableAfternoonAvailable').DataTable().columns.adjust().responsive.recalc();
                $("#loading").modal("hide");
            }, 500);
        </script>
    }
}
else
{
    <script>
        $(".reservedDiv").addClass("hidden");
    </script>
}

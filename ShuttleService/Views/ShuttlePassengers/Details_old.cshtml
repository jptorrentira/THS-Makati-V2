@section Scripts {
    <script>
    function Reservation() {
            var dtimestamp = @ViewBag.unixtime;
            var dateToday = new Date();
            var tomorrow = new Date();
            tomorrow.setDate(tomorrow.getDate() + 1);




        if (dateToday >= dtimestamp || (tomorrow >= dtimestamp && dateToday.getHours() >= 16) ) {
                swalAlertOnly('Error','Invalid Reservation Date.','error');
            } else {
            window.location.href = '@Url.Content("~/shuttlepassengers/create?d=")' + (dtimestamp / 1000);
            }
    }
    </script>
}


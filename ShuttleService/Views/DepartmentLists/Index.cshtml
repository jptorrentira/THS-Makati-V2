@model IEnumerable<ShuttleService.Models.DepartmentList>
@{
    ViewData["Title"] = "Department Lists";
}

<div class="row">
    <div class="col-md-10 pull-left">
        <h4>Manage Department</h4>
    </div>
</div>
<div class="wrapper wrapper-content animated fadeInRight white-bg">

    <div class="row">
        <div class=" col-sm-12">
            <a href="javascript:void(0);" onClick="Create()" class="btn btn-warning">Add New</a>
        </div>
    </div>
    <div class="row">
        <div class=" col-sm-12">
            <div class=" col-sm-12">
                <table id="data_table" class="table table-striped table-bordered table-hover text-center table100"></table>

            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="ModalManage" tabindex="-1" role="dialog" style="z-index: 99990 !important;" data-backdrop="false" data-keyboard="false">
    <div class="modal-dialog modal-lg" role="document">
        <div class="modal-content modal-col-red">
            <div class="modal-header">
                <label class="modal-title">Manage Department</label>
            </div>
            <div class="modal-body form-horizontal">
                <form id="ManageForm">
                    <div class="form-group ">
                        <label class="control-label col-sm-3">ID:</label>
                        <div class="col-sm-6">
                            <input id="id" name="id" class="form-control" readonly value="" />
                        </div>
                    </div>
                    <div class="form-group ">
                        <label class="control-label col-sm-3">Department Name:</label>
                        <div class="col-sm-6">
                            <input id="DepartmentName" class="form-control required" placeholder="Department Name" name="DepartmentName" />

                        </div>
                    </div>

                    <div class="form-group ">
                        <label class="control-label col-sm-3">Department Code:</label>
                        <div class="col-sm-6">
                            <input id="ShortName" class="form-control required" placeholder="ShortName" name="ShortName" />
                        </div>
                    </div>

                    <div class="form-group ">
                        <label class="control-label col-sm-3">Company:</label>
                        <div class="col-sm-6">
                            <select id="CompanyListId" class="form-control input-sm " name="CompanyListId" asp-items="ViewBag.CompanyListId">
                                <option value="" selected>--Please Select--</option>
                            </select>
                            @*<input id="CompanyListId" class="form-control required" placeholder="CompanyListId" name="CompanyListId" />*@
                        </div>
                    </div>

                </form>

            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-w-m btn-danger" data-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-w-m btn-primary" onclick="Save();">Save</button>
            </div>
        </div>
    </div>
</div>



<script>
    $('#Sections').select2({
        'width': "100%"
    });

    $('#data_table thead tr').clone(true).appendTo('#data_table thead');
    $('#data_table thead tr:eq(1) th').each(function (i) {
        var title = $(this).text();
        if (title != "Action") {
            $(this).html('<input type="text" class="form-control input-xs" placeholder="Search ' + title + '"  data-index="' + i + '" />');
        }

        $('input', this).on('keyup change', function () {
            if (table.column(i).search() !== this.value) {
                table
                    .column(i)
                    .search(this.value)
                    .draw();

            }
        });
    });

    var reloader = 0;
    var table = $('#data_table').DataTable({
        pageLength: 25,
        //responsive: true,
        // dom: '<"html5buttons"B>lTfgitp',
        buttons: [
            { extend: 'copy' },
            { extend: 'csv' },
            { extend: 'excel', title: 'ExampleFile' },
            { extend: 'pdf', title: 'ExampleFile' },

            {
                extend: 'print',
                customize: function (win) {
                    $(win.document.body).addClass('white-bg');
                    $(win.document.body).css('font-size', '10px');

                    $(win.document.body).find('table')
                        .addClass('compact')
                        .css('font-size', 'inherit');
                }
            }
        ],
        processing: true,
        serverSide: true,
        autoWidth: false,
        scrollX: true,
        //responsive: true,
        bLengthChange: false,
        orderCellsTop: true,
        "ajax": {
            "url": "@Url.Content("~/departmentlists/ShowLists")",
            "type": "POST"
        },
        "columns": [
            { "data": "id", title: "Action", width: "5%", visible: false, align: "center", orderable: false },
            {
                title:"Action",
                data: null,
                orderable: false,
                width: "20%",
                className: "center",
                render: function (data, type, full, meta) {
                    var btnCounter = 0;
                    var btn = '<div class="btn-group "><button data-toggle="dropdown" class="btn btn-primary btn-sm dropdown-toggle">Action <span class="caret"></span></button> <ul class="dropdown-menu">';
                            btn = btn + `<li><a href="javascript:void(0);" onClick="Edit(` + data["id"] +`)"><span class="fa fa-edit"></span>&nbsp;Edit</a></li>`;
                            btnCounter++;


                    btn = btn + '</ul></div>';

                    if (btnCounter <= 0) btn = "";
                    return btn;
                }
            },
            { "data": "companyListName", title: "Company" },
            { "data": "name", title: "Department Name" },
            { "data": "shortName", title: "Short Name"},
            { "data": "encodedBy", title: "Encoded By" },
            { "data": "encodeDate", title: "Encoded Date" },
            { "data": "lastModifiedBy", title: "Last Modified By" },
            { "data": "modifyDate", title: "Last Modified Date" }
        ]
        ,
        'select': {
            'style': 'single'
        },
        'columnDefs': [
            {
                "targets": "_all", // your case first column
                "className": "text-center"
            }],
        "order": [[0, "desc"]],
        "initComplete": function (settings, json) {


        }
    });


    function Edit(id) {
        //
        checkCompany();
        $("#ModalLoading").css('display', 'block');
          $.ajax({
            type: "POST",
            url: "@Url.Content("~/departmentlists/ShowData")?id="+id,
            //data: $("#RequestForm").serialize(),
            //"contentType": "application/json; charset=utf-8",
            dataType: "JSON",
            success: function (data, textStatus, jqXHR) {

                $("#ModalLoading").css('display', 'none');
            if (data.success == 1) {

                $("#id").val(data.recordId);
                $("#DepartmentName").val(data.departmentName);
                $("#ShortName").val(data.shortName);
                $("#CompanyListId").val(data.companyListId).change();


                $('body').addClass('modal-open');
                $("#ModalManage").modal("show");


            } else {
                swalAlertOnly("Error", data.message, "error");
            }
            }
            });

        //
    }

    function Create() {
        $("#id").val("");
        $("#DepartmentName").val("");
        $("#ShortName").val("");
        $("#CompanyListId").val("").change();
        $("input[name='isCharging']").prop('checked', false);
        $('body').addClass('modal-open');
        
        checkCompany();
        $("#ModalManage").modal("show");
    }

     function Save() {

         if ($("#DepartmentName").val() == '' || $("#ShortName").val() == '') {

             swalAlertOnly("Error", "Please complete all details.", "error");
             return false;
         }

                if ($("#id").val() == "") {
                    $("#id").val("0");
                }
                var _link = "@Url.Content("~/departmentlists/edit")";


            swal({
            title: "Are you sure?",
            text: "Please make sure that all your input is correct.",
            type: "warning",
            showCancelButton: true,
            confirmButtonColor: "#DD6B55",
            confirmButtonText: "Proceed!",
            closeOnConfirm: false
            }, function () {

                $("#ModalLoading").modal("show");
                $("#ModalLoading").css('display', 'block');
            $.ajax({
            type: "POST",
            url: _link,
            data: $("#ManageForm").serialize(),
            //"contentType": "application/json; charset=utf-8",
            dataType: "JSON",
            success: function (data, textStatus, jqXHR) {

                $("#ModalLoading").css('display', 'none');
            if (data.success == 1) {

                        //window.removeEventListener("beforeunload", functionToRun);


                       //reload the page
                                swal({
                                                title: "Success",
                                                text: "Saved.",
                                                type: "success"
                                            },
                                    function () {
                                        table.draw();
                                });
                            //end reload the page

                $('body').removeClass('modal-open');
                $("#ModalManage").modal("hide");

            } else {

            swalAlertOnly("Error", data.message, "error");
            }
            }
            });

            });

    }


    
    function checkCompany() {

        return false;
        $("#CompanyListId").select2({
            ajax: {
                type: "POST",
                url: "@Url.Content("~/CompanyList/getCompanyList")" ,
                dataType: 'json',
                delay: 250,
                data: function (params) {
                    return {
                        q: params.term, // search term
                        page: params.page
                    };
                },
                processResults: function (data, page) {
                    // parse the results into the format expected by Select2.
                    // since we are using custom formatting functions we do not need to
                    // alter the remote JSON data
                    return {
                        results: data.items
                    };
                },
                cache: false
            },
            minimumInputLength: 1,
            width: '100%'
        });

    }
</script>
<div class="wrapper wrapper-content animated fadeInRight white-bg">
    <div class="form-group">
        <div class="row clearfix">
            <form id="VehicleGraphForm">
                <div class="col-md-1"><label class="pull-left" style="color: black!important">Date Filter:</label> </div>
                <div class="col-md-2">
                    <input class="form-control input-sm datepicker text-center " readonly="readonly" id="VehicleChartFilter" name="VehicleChartFilter" type="text">
                </div>
                <div class="col-md-1">
                    <a class="btn btn-sm btn-primary waves-effect waves-lightblue" onclick="LoadVehicleSchedule()"> Show</a>
                </div>
            </form>
        </div>
    </div>
    <div class="form-group">
        <div class="row clearfix">
            <div class="col-sm-12">
                <div id="container"></div>
            </div>
        </div>
    </div>
    <div class="form-group">
        <div class="row clearfix">
            <div class="col-sm-12">
                <div id="container2"></div>
            </div>
        </div>
    </div>
</div>
    <script>
        var options = {
            chart: {
                renderTo: 'container',
                type: 'xrange'
            },
           
            title: {
                text: 'Vehicle Schedule'
            },
            accessibility: {
                point: {
                    descriptionFormatter: function (point) {
                        var ix = point.index + 1,
                            category = point.yCategory,
                            driver = point.driver,
                            from = new Date(point.x),
                            to = new Date(point.x2);
                        return ix + '. ' + category + ', ' + from.toDateString() +
                            ' to ' + to.toDateString();
                    }
                }
            },
            tooltip: {
                formatter: function () {
                    return 'From: <b>' + this.point.t1 + '</b><br/>' + 'To: <b>' + this.point.t2 + '</b><br/>Location: ' + this.point.location + '<br/>Driver: ' + this.point.driver;
                }
            },
            plotOptions: {
                series: {
                    dataLabels: {
                        enabled: true,
                        allowOverlap: true,
                        inside: true,
                        overflow: false,
                    }
                }
            },
            xAxis: {
                type: 'datetime',
                opposite: true
            },
            yAxis: {
                title: {
                    text: ''
                },
                //categories: [, , , 'Vehicle 4', 'Vehicle 5', 'Vehicle 6', 'Vehicle 7', 'Vehicle 8', 'orayt'],
                reversed: true
            },
            series: [{
                dataLabels: [{
                    align: 'center',
                    format: '{point.location} {point.company}',
                    style: {
                        fontSize: "10px",
                        fontWeight: "normal",
                        overflow: false,
                        textOutline: ".5px contrast",
                    }
                }],
                name: '',
                // pointPadding: 0,
                // groupPadding: 0,
                borderColor: 'gray',
                pointWidth: 20
            }
            ]

        };



        var options2 = {
            chart: {
                renderTo: 'container2',
                type: 'xrange'
            },

            title: {
                text: 'Driver Schedule'
            },
            accessibility: {
                point: {
                    descriptionFormatter: function (point) {
                        var ix = point.index + 1,
                            category = point.yCategory,
                            driver = point.driver,
                            from = new Date(point.x),
                            to = new Date(point.x2);
                        return ix + '. ' + category + ', ' + from.toDateString() +
                            ' to ' + to.toDateString();
                    }
                }
            },
            tooltip: {
                formatter: function () {
                    return 'From: <b>' + this.point.t1 + '</b><br/>' + 'To: <b>' + this.point.t2 + '</b><br/>Location: ' + this.point.location + '<br/>Driver: ' + this.point.driver;
                }
            },
            plotOptions: {
                series: {
                    dataLabels: {
                        enabled: true,
                        allowOverlap: true,
                        inside: true,
                        overflow: false,
                    }
                }
            },
            xAxis: {
                type: 'datetime',
                opposite: true
            },
            yAxis: {
                title: {
                    text: ''
                },
                //categories: [, , , 'Vehicle 4', 'Vehicle 5', 'Vehicle 6', 'Vehicle 7', 'Vehicle 8', 'orayt'],
                reversed: true
            },
            series: [{
                dataLabels: [{
                    align: 'center',
                    format: '{point.location} {point.company}',
                    style: {
                        fontSize: "10px",
                        fontWeight: "normal",
                        overflow: false,
                        textOutline: ".5px contrast",
                    }
                }],
                name: '',
                // pointPadding: 0,
                // groupPadding: 0,
                borderColor: 'gray',
                pointWidth: 20
            }
            ]

        };
        

    </script>
    <script>
    function LoadVehicleSchedule() {
        var _date = $("#VehicleChartFilter").val();

        var urlString = "@Url.Content("~/trips/LoadVehicleSchedule")" + "?dateFilter=" + _date;

        $.ajax({
            type: "POST",
            url: urlString,
            //"contentType": "application/json; charset=utf-8",
            dataType: "JSON",
            async: false,
            success: function (data, textStatus, jqXHR) {
                if (data.status == "OK") {
                      
                    options.series[0].data = data['trip'];
                    options.yAxis.categories = data['vehicleNames'];
                    new Highcharts.Chart(options);
                }
                else {
                    //alert(data.message);
                }
            }
        });

         var urlString2 = "@Url.Content("~/trips/LoadDriverSchedule")" + "?dateFilter=" + _date;

        $.ajax({
            type: "POST",
            url: urlString2,
            //"contentType": "application/json; charset=utf-8",
            dataType: "JSON",
            async: false,
            success: function (data, textStatus, jqXHR) {
                if (data.status == "OK") {
                      
                    options2.series[0].data = data['trip'];
                    options2.yAxis.categories = data['driverNames'];
                    new Highcharts.Chart(options2);
                }
                else {
                    //alert(data.message);
                }
            }
        });
    }

    $("#VehicleChartFilter").datepicker();

    $("#VehicleChartFilter").val('');
    LoadVehicleSchedule();
    </script>


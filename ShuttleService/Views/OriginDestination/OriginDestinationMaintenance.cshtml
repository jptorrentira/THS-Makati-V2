@{
}

<style>
    .select2-container {
        z-index: 99999 !important;
    }
</style>
<div class="wrapper-content">
    <div>
        <h4>Origin & Destination List</h4>
    </div>
</div>


<div class="row">
    <div class=" col-sm-12">
        <a href='javascript:void(0);' onClick='Add()' class='btn btn-sm btn-success'> Add Origin & Destination </a>
    </div>
    <div class=" col-sm-12">
        <table id="data_table" class="table table-striped table-bordered table-hover text-center table100"></table>

    </div>
</div>

<div class="modal fade" role="dialog" id="modal-edit" style="z-index: 9990!important;" data-backdrop="static" data-keyboard="false">
    <div class="modal-dialog modal-md" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h3>Origin & Destination Information.</h3>
            </div>
            <form id="formData">
                <input type="hidden" name="Id" id="Id" />
                <input type="hidden" name="InsertBy" id="InsertBy" />
                <div class="modal-body form-horizontal">
                    <div class="row">
                        <div class="form-group">
                            <div class="col-sm-4">
                                <label class="control-label"> Origin & Destination Name: </label>
                            </div>
                            <div class="col-sm-8">
                                <input class="form-control input-sm " id="OriginDestinationName" name="OriginDestinationName" />
                            </div>
                        </div>
                    </div>
                    <div class="row">
                        <div class="form-group">
                            <div class="col-sm-4">
                                <label class="control-label"> Status </label>
                            </div>
                            <div class="col-sm-8">
                                <select name="Status" id="Status" style="z-index: 99999!important;" class="form-control">
                                    <option disabled selected>--- SELECT ---</option>
                                    <option value="true">Active</option>
                                    <option value="false">Inactive</option>
                                </select>
                            </div>
                        </div>
                    </div>
                </div>
            </form>
            <div class="modal-footer">
                <div class="btn-group pull-right">
                    <button class="ladda-button btn btn-primary" onClick="SaveUpdate();" id="btnSave" type="button" data-style="expand-left">Save</button>
                    <button class="btn btn-danger" type="button" data-dismiss="modal">Close</button>
                </div>
            </div>
        </div><!-- /.modal-content -->
    </div><!-- /.modal-dialog -->
</div><!-- /.modal -->


<environment include="Development,Staging,Production">
    <!-- DataTables -->
    @section Scripts {
        <script src="https://repo.aunasin.com/assets/tths/vendors/datatables.net/js/jquery.dataTables.min.js"></script>
        <script src="https://repo.aunasin.com/assets/tths/vendors/datatables.net-bs/js/dataTables.bootstrap.min.js"></script>
        <script src="https://repo.aunasin.com/assets/tths/vendors/datatables.net/js/dataTables.select.min.js"></script>
    }
</environment>
<script>
    var reloader = 0;
    var table1 = $('#data_table').DataTable({
            "processing": false,
            "serverSide": true,
            "autoWidth": false,
            "searching": true,
            "scrollX": true,
            "bLengthChange": false,
            "ajax": {
                "url": "@Url.Content("~/origindestination/ShowOriginDestinationLists")",
                "type": "POST"
            },
            "columns": [

                // { "data": "id", title: "ID", width: "5%", align: "center", visible: false, orderable: false },
                { "data": "action", title: "Action", orderable: false },
                { "data": "originDestinationName", title: "Origin & Destination Name", orderable: false },
                { "data": "insertBy", title: "Insert By", orderable: false },
                { "data": "insertDate", title: "Insert Date", orderable: false },
                { "data": "updatedBy", title: "Updated By", orderable: false },
                { "data": "updatedDate", title: "Updated Date", orderable: false },
                {
                    "data": "status",
                    "title": "Status",
                    "orderable": false,
                    "render": function (data, type, row) {
                        return data ? "Active" : "Inactive";
                    }
                }
            ]
            ,
            'select': {
                'style': 'single'
            },
            'columnDefs': [
                {
                    "targets": "_all", // your case first column
                    "className": "text-center",
                }],
            "order": [[2, "asc"]],
            "initComplete": function (settings, json) {
                if (reloader == 0) {
                    reloader = 1;
                    var myVar = setInterval(function () {
                        $('#data_table').DataTable().columns.adjust().draw();
                        clearInterval(myVar);
                    }, 500);

                }
            }
        });

    function Add() {
        $('#formData').trigger("reset");
        $('#Id').val("0");
        $("#modal-edit").modal("show");
    }
    function Edit(id) {
            $.ajax({
                    type: "GET",
                    url: "@Url.Content("~/origindestination/GetOriginDestination")?id=" + id,

                    //"contentType": "application/json; charset=utf-8",
                    dataType: "JSON",
                    success: function (data, textStatus, jqXHR) {
                        if (data.success == 1) {
                            $("#OriginDestinationName").val(data['userData'][0].originDestinationName);
                            $("#Status").val(data['userData'][0].status.toString()).trigger("change");
                            $("#Id").val(data['userData'][0].id);
                            $("#modal-edit").modal("show");

                        } else {
                            swalAlertOnly("Error", data.message, "error");
                        }
                    }
                });
    }

    function SaveUpdate() {
        if ($("#OriginDestinationName").val() == '' || $("#Status").val() == null) {

            swalAlertOnly("Error", "Please complete all details.", "error");
        }
        else {
            swal({
                title: "Are you sure?",
                text: "This will update the details for this origin & destination",
                type: "warning",
                showCancelButton: true,
                confirmButtonColor: "#DD6B55",
                confirmButtonText: "Yes, Save it!",
                closeOnConfirm: false
            }, function () {

                SubmitForm();

            });
        }
    }


    function SubmitForm() {
        $("#loading").modal("show");
        console.log($("#formData").serialize());
        $.ajax({
            type: "POST",
            url: "@Url.Content("~/origindestination/SaveUpdateOriginDestination/")" + $("#Id").val(),
            data: $("#formData").serialize() + "&id=" + $("#Id").val(),
            //"contentType": "application/json; charset=utf-8",
            dataType: "JSON",
            success: function (data, textStatus, jqXHR) {
                //console.log(data);
                if (data.success == 1) {
                    $('#data_table').DataTable().clear().draw();
                    $('#data_table').DataTable().ajax.reload();
                    $("#modal-edit").modal("hide");
                    swalAlertOnly("Success", data.message, "success");
                } else {
                    swalAlertOnly("Error", data.message, "error");
                }
                $("#loading").modal("hide");
            }
        });
    }
</script>
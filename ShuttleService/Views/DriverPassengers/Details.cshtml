@model ShuttleService.Models.DriverPassenger

@{
    ViewData["Title"] = "Details";
}
<style>
</style>
<div class="wrapper-content row">
    <div class="col-md-6">
        <h4>Driver/Vehicle Schedule</h4>
    </div>
    <div class="col-md-6 ">
        <div class="btn-group pull-right">
            <button type="button" class="btn btn-w-m btn-primary btn-block" onclick="Reservation();">Reservation</button>
            <button type="button" class="btn btn-w-m btn-danger btn-block" onclick="GoBack('@Url.Content("~/driverpassengers")')">Back</button>
        </div>
    </div>
</div>

<div class="wrapper wrapper-content animated fadeInRight white-bg">


    <div class="">
        <div class="row">
            <div class=" col-sm-12">
                <label style="font-style:italic;">Driver/Vehicle Reservations</label>
                <br />
                <table id="tableDriverVehicle" class="table table-striped table-bordered table-hover text-center table100 ">
                    <thead>
                        <tr>
                            <th class="text-center ebeTable">
                                Action
                            </th>
                            <th class="text-center ebeTable">
                                Request No
                            </th>
                            <th class="text-center ebeTable">
                                Requested By
                            </th>
                            <th class="text-center ebeTable">
                                Origin
                            </th>
                            <th class="text-center ebeTable">
                                Destination
                            </th>
                            <th class="text-center ebeTable">
                                Time
                            </th>
                            <th class="text-center ebeTable">
                                Instruction
                            </th>   
                            <th class="text-center ebeTable">
                                Purpose
                            </th>
                            <th class="text-center ebeTable">
                                No. Of Passengers
                            </th>
                            <th class="text-center ebeTable">
                                Assigned Driver
                            </th>
                            <th class="text-center ebeTable">
                                Assigned Vehicle
                            </th>
                            <th class="text-center ebeTable">
                                Status
                            </th>
                            <th class="text-center ebeTable">
                                Remarks
                            </th>
                        </tr>
                    </thead>
                </table>
            </div>
        </div>
    </div>


</div>
@section Scripts {
    <script>
        function Reservation() {

            var dtimestamp = @ViewBag.unixtime;
            var dateToday = new Date();
            var tomorrow = new Date();
            tomorrow.setDate(tomorrow.getDate() + 1);

            //commented as AGS' Request during ECQ
            //if (dateToday >= dtimestamp || (tomorrow >= dtimestamp && dateToday.getHours() >= 16) ) {
            //        swalAlertOnly('Error','Invalid Reservation Date.','error');
            //    } else {
                //}
            //end commented as AGS' Request during ECQ

            $.ajax({
            type: "POST",
            url: "@Url.Content("~/SurveyTransactions/CheckSurveyCounts")",
            dataType: "JSON",
            async: false,
            success: function (data, textStatus, jqXHR) {
                if (data.surveyCount >= 3) {
                    swalAlertOnly('Error', 'You have 3 or more unanswered surveys. You are not allowed to create a reservation.', 'error');
                }
                else {
                    window.location.href = '@Url.Content("~/driverpassengers/create?t=0")' +"&tempid=0&d=" + (dtimestamp / 1000);
                }
                
            }
            });

     




      
    }
    </script>
}

<script>
    $('#tableDriverVehicle').DataTable({
        "processing": false,
        "serverSide": true,
        "autoWidth": false,
         "searching": false,
         "ordering": false,
        "scrollX": true,
        "bLengthChange": false,
        "pageLength": 100,
        "ajax": {
            "url": "@Url.Content("~/driverpassengers/CheckPassengerReservation")",
            "type": "POST",
            "data": function (d) {
                var dtimestamp = @ViewBag.unixtime;
                d.triptype = "morning";
                d.timestamp = dtimestamp/1000;
            }
        },
        "columns": [
            { "data": "action", title: "Action", width: "5%", orderable: false },
            { "data": "no", title: "Request No",width: "5%", orderable: false},
            { "data": "name", title: "Requested By", width: "30%", orderable: false },
            { "data": "origin", title: "Origin", width: "15%", orderable: false },
            { "data": "destination", title: "Destination", width: "20%", orderable: false },
            { "data": "time", title: "Time", width: "20%", orderable: false },
            { "data": "instruction", title: "Instruction", width: "20%", orderable: false },
            { "data": "purpose", title: "Purpose", width: "20%", orderable: false },
            { "data": "passengerCount", title: "No. Of Passengers", width: "20%", orderable: false },
            { "data": "assignedDriver", title: "Assigned Driver", width: "20%", orderable: false },
            { "data": "assignedVehicle", title: "Assigned Vehicle", width: "20%", orderable: false },
            { "data": "statusDescription", title: "Status", width: "20%", orderable: false },
            { "data": "remarksTrip", title: "Remarks", width: "20%", orderable: false }
        ]
        ,
        'select': {
            'style': 'single'
        },
         "order": [[1, "desc"]]
            });


</script>

		function RemoveEmployeeAjax(id) {

		swal({
		title: "Are you sure?",
		text: "This will remove the reservation for this person!",
		type: "warning",
		showCancelButton: true,
		confirmButtonColor: "#DD6B55",
		confirmButtonText: "Yes, remove it!",
		closeOnConfirm: false
		}, function () {


			$("#ModalLoading").modal("show");
			$("#ModalLoading").css('display', 'block');
		$.ajax({
		type: "POST",
		url: "@Url.Content("~/driverpassengers/removeReservation")/"+id+"?Id=" + id,
		//"contentType": "application/json; charset=utf-8",
		dataType: "JSON",
		success: function (data, textStatus, jqXHR) {

			$("#ModalLoading").css('display', 'none');
		if (data.success == 1) {
		$('#data_table_rec1').DataTable().clear().draw();
		$('#data_table_rec1').DataTable().ajax.reload();
		swal("Removed!", "Reservation has been removed.", "success");
		} else {
		swalAlertOnly("Error", data.message, "error");
		}

		}
		});

		});

		}


		function Submit() {

			swal({
				title: "Are you sure?",
				text: "You cannot add more passenger once submitted!",
				type: "warning",
				showCancelButton: true,
				confirmButtonColor: "#DD6B55",
				confirmButtonText: "Submit!",
				closeOnConfirm: false
			}, 
			function () {
				var checkifapprover = "@ViewBag.OverAllApprover";
				var _url = "";
				if (checkifapprover == "1") {
					_url = "@Url.Content("~/driverpassengers/approveBypass")/@ViewBag.dget?timestamp=@ViewBag.dget&tid=@ViewBag.tget";
				}
				else {
					_url = "@Url.Content("~/driverpassengers/submitReservation")/@ViewBag.dget?timestamp=@ViewBag.dget&tid=@ViewBag.tget";
				}

				$("#ModalLoadingSMS").modal("show");
				$("#ModalLoadingSMS").css('display', 'block');
				$.ajax({
					type: "POST",
					url: _url,
					//"contentType": "application/json; charset=utf-8",
					dataType: "JSON",
					success: function (data, textStatus, jqXHR) {

						$("#ModalLoadingSMS").css('display', 'none');
						if (data.success == 1) {
							$('#data_table_rec1').DataTable().clear().draw();
							$('#data_table_rec1').DataTable().ajax.reload();

						window.removeEventListener("beforeunload", functionToRun);


									//reload the page
											swal({
															title: "Success",
															text: "Reservation has been submitted." + data.otherReservation,
															type: "success"
														},
												function () {
													var checkifFromTrip = "@ViewBag.FromTrip";
													if (checkifFromTrip != "") {
														window.location.href = "@Url.Content("~/trips/AssignTrip")" + "?d=@ViewBag.dget&t=@ViewBag.tget&tempid=@ViewBag.tempid";
													}
													else {
														window.location.href = "@Url.Content("~/driverpassengers/details")" + "?d=@ViewBag.dget";
													}

											});
										//end reload the page

							$("#btnAddToList").addClass("hidden");
							$("#btnSubmit").addClass("hidden");
							$(".ChargingGroup").addClass("hidden");
							$(".PassengerGroup").addClass("hidden");

						} else {

							swalAlertOnly("Error", data.message, "error");
						}
					}
				});

			});

		}


		function ValidatePassengerType() {

			$("#CompanyListId").val("");
			$("#CompanyOther").val("");
			$("#Nationality").val("Filipino").trigger("change");
			$("#Gender").val("Male").trigger("change");

		if ($("#PassengerTypeId").val() == 2) {

			$("#EmployeeNo").closest("div").find(".field-validation-error").empty();
			$("#EmployeeNo").removeClass("input-validation-error");

			//$('#CompanyOther').validate();
			$("#EmployeeNo").val("");
			$("#EmployeeNo").attr('disabled', 'disabled');
			$("#EmployeeNo").rules("remove");

			$(".ContactNoGroup").removeClass('hidden');
			$("#divForCompanyID").addClass('hidden');
			$("#CompanyOther").removeAttr( 'disabled');
			$("#CompanyOther").rules("add", {
				required: true
			});
			$('.clear-search').hide();
		}
		else {
			$("#ChargingCompanyId").val('').change();
			$("#ChargingDepartmentId").val('').change();
			$(".ContactNoGroup").removeClass('hidden');
			$(".ContactNoGroup").addClass('hidden');
			$("#CompanyOther").closest("div").find(".field-validation-error").empty();
			$("#CompanyOther").removeClass("input-validation-error");

			$("#divForCompanyID").removeClass('hidden');
			$("#CompanyOther").attr('disabled', 'disabled');
			$("#CompanyOther").rules("remove");

			$("#EmployeeNo").removeAttr('disabled');
			$("#EmployeeNo").rules("add", {
				required: true
			});
			$('.clear-search').show();
		}

			//default charging
			$("#ChargingCompanyId").val('@ViewBag.defaultChargingCompanyId').change();
			$("#ChargingDepartmentId").append("<option value='@ViewBag.defaultChargingDepartmentId'>@ViewBag.defaultChargingDepartmentName</option>").val('@ViewBag.defaultChargingDepartmentId').change();
			//end

			var checkifapprover = "@ViewBag.OverAllApprover";
			if (checkifapprover != "1") {
				$("#ChargingCompanyId").attr("disabled", true);
				$("#ChargingDepartmentId").attr("disabled", true);
			}


		}

		function CheckCompanyList() {

			$("#CompanyOther").val("");

			if ($("#CompanyListId").val() == 1) {
				$("#CompanyOther").removeAttr('disabled');
				$("#CompanyOther").rules("add", {
					required: true
				});
			}
			else {
				$("#CompanyOther").closest("div").find(".field-validation-error").empty();
				$("#CompanyOther").removeClass("input-validation-error");
				$("#CompanyOther").attr('disabled', 'disabled');
				$("#CompanyOther").rules("remove");
				}
		}

		function DisableLookupElement() {
			$(".lookupElement:input").attr("disabled",true);
		}

		function EnableLookupElement() {
			$(".lookupElement:input").removeAttr("disabled");

			$(".select2").select2({ placeholder: "Please Select" });
		}
		function resetLookupElement() {
			$(".lookupElement:input").removeAttr("readonly");
			$(".lookupElement:input").val("");
			EnableLookupElement();
			$("#PassengerTypeId").val("1");

		}

		function checkChargingDepartment() {


		$("#ChargingDepartmentId").select2({
		ajax: {
			type: "POST",
			url: "@Url.Content("~/employees/getChargingDepartmentList?companyId=")" + $("#ChargingCompanyId").val(),
			dataType: 'json',
			delay: 250,
			data: function (params) {
				return {
				q: params.term, // search term
				page: params.page
			};
		},
		processResults: function (data, page) {
		// parse the results into the format expected by Select2.
			// since we are using custom formatting functions we do not need to
			// alter the remote JSON data
			return {
				results: data.items
			};
		},
		cache: false
		},
			minimumInputLength: 1,
			width: '100%'
			});

			$("#ChargingDepartmentId").val("").trigger('change');
		}

	$(document).ready(function () {
		ValidatePassengerType();
		CheckCompanyList();
		$(".select2").select2({ placeholder: "Please Select" });

		// Handle toggle switch (With / Without passengers)
		// when checkbox changes
		$("#ServiceTypeId").on("change", function () {
			let selectedText = $("#ServiceTypeId option:selected").text();

			if (selectedText === "No Passenger") {

				$("#PassengerTypeId").val("2").trigger("change").prop("disabled", true);
				$("#CompanyOther").val("NO PASSENGER").prop("readonly", true);
				$("#FirstName").val("NO PASSENGER").prop("readonly", true);
				$("#MiddleName").val("NO PASSENGER").prop("readonly", true);
				$("#LastName").val("NO PASSENGER").prop("readonly", true);
				$("#Position").val("NO PASSENGER").prop("readonly", true);
				$("#ContactNo").val("").prop("readonly", true);

				$("#Nationality").val("Filipino").trigger("change").prop("disabled", true);
				$("#Gender").val("Male").trigger("change").prop("disabled", true);

				ensureHidden("PassengerTypeIdHidden", "PassengerTypeId", "2");
				ensureHidden("NationalityHidden", "Nationality", "Filipino");
				ensureHidden("GenderHidden", "Gender", "Male");

				$('.clear-search').hide();
				// Show note
				$("#noPassengerNote").fadeIn();
			}
			else {
				$("#PassengerTypeId").val("").trigger("change").prop("disabled", false);
				$("#CompanyOther, #FirstName, #MiddleName, #LastName, #ContactNo, #Position")
					.val("").prop("readonly", false);

				$("#Nationality").val("").trigger("change").prop("disabled", false);
				$("#Gender").val("").trigger("change").prop("disabled", false);

				$('.clear-search').show();
				// Hide note
				$("#noPassengerNote").fadeOut();
			}
		});

		// Helper function to add/update hidden inputs
		function ensureHidden(hiddenId, name, value) {
			if ($("#" + hiddenId).length === 0) {
				$("<input>").attr({
					type: "hidden",
					id: hiddenId,
					name: name,
					value: value
				}).appendTo("form");
			} else {
				$("#" + hiddenId).val(value);
			}
		}

		// Run once on page load
		$("#togglePassengers").trigger("change");
	});

</script>
<script>

	function checkOrigin() {
		if ($("#OriginId").text() == "Makati HO") {
			$("#Origin").val("Makati HO");
			$("#Origin").attr("readonly", "readonly");
		}
		else if ($("#OriginId").val() == "CPC") {
			$("#Origin").val("CPC");
			$("#Origin").attr("readonly", "readonly");
		}
		else {
			$("#Origin").val("");
			$("#Origin").removeAttr("readonly");
		}
	}
	function checkDestination() {
		if ($("#DestinationId").val() == "Makati HO") {
			$("#Destination").val("Makati HO");
			$("#Destination").attr("readonly", "readonly");
		}
		else if ($("#DestinationId").val() == "CPC") {
			$("#Destination").val("CPC");
			$("#Destination").attr("readonly", "readonly");
		}
		else {
			$("#Destination").val("");
			$("#Destination").removeAttr("readonly");
		}
	}

</script>


@if (_dhead != null)
{
	if (_dhead.Id > 0)
	{
		<script>
			$("#TripTimeFrom").val("@_dhead.TripTimeFrom");
			$("#TripTimeTo").val("@_dhead.TripTimeTo");
			$("#Instructions").val(`@_dhead.Instructions`);
			$("#Purpose").val(`@_dhead.Purpose`);
			$("#ServiceTypeId").val(`@_dhead.ServiceTypeId`).change();
			$("#OriginId").val(`@_dhead.OriginId`);
			$("#DestinationId").val(`@_dhead.DestinationId`);
				$("#UnplannedTrip").val(`@_dhead.UnplannedTrip`).change();
			checkDestination();
			checkOrigin();
			$("#Origin").val(`@_dhead.Origin`);
			$("#Destination").val(`@_dhead.Destination`);

		</script>


		if (_dhead.EmployeeId != ViewBag.EmployeeId && ViewBag.OverAllApprover != 1)
		{
			<script>
				$("#btnAddToList").addClass("hidden");
				$("#btnSubmit").addClass("hidden");
				$("#ShuttleForm").addClass("hidden");

			</script>
		}
		else if ((_dhead.ShuttleId > 0 || _dhead.Status == 5 || _dhead.Status == 1) && ViewBag.OverAllApprover != 1)
		{

			<script>
				$("#btnAddToList").addClass("hidden");
				$("#btnSubmit").addClass("hidden");
				$(".ChargingGroup").addClass("hidden");
				$(".PassengerGroup").addClass("hidden");

			</script>
		}
		else
		{
			<script>
				window.addEventListener("beforeunload", functionToRun);
			</script>
		}

	}
}


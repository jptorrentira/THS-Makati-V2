<script>

    function cancelTrip(id) {

            CancelGroup(1,id);
    }
    function declineTrip(id) {


            CancelGroup(2,id);
    }

    function CancelDeclineTrip() {

        if ($.trim($("#CancelDeclineReason").val()) == "") {
            swalAlertOnly("Error", "Please provide reason", "error");
            return false;
        } else {

                    var mode = $("#CancelDeclineMode").val();
                    var title = "";

                    if (mode == 1) {
                        title = "Cancel";
                    } else if (mode == 2) {
                        title = "Decline";
                    }


                    swal({
                        title: "Are you sure?",
                        text: "This will " + title+" all the selected person(s)",
                        type: "warning",
                        showCancelButton: true,
                        confirmButtonColor: "#18a689",
                        confirmButtonText: "Yes, " + title+" it!",
                        closeOnConfirm: false
                    }, function () {

                        Proceed($("#CancelDeclineMode").val(), $("#CancelDeclineId").val());

                            });
        }
    }


    function CancelGroup(mode, id) {

        $("#ModalCancelDeclineRemarks").modal("show");
        $("#CancelDeclineId").val(id);
        $("#CancelDeclineMode").val(mode);
        $("#CancelDeclineReason").val("");


        if (mode == 1) {
            $("#CancelDeclineTitle").text("Cancel Reason:");
        }
        else if (id == 2) {
            $("#CancelDeclineTitle").text("Decline Reason:");
        }


    }

    function Proceed(method, id) {

        $("#ModalLoadingSMS").modal("show");
        $("#ModalLoadingSMS").css('display', 'block');
        var _url = "@Url.Content("~/shuttlepassengers/DeclineCancel/")" + id ;


        $.ajax({
                type: "POST",
                url: _url,
                data: "id=" + id + "&method=" + method+ "&CancelDeclineReason=" + $("#CancelDeclineReason").val(),
                //"contentType": "application/json; charset=utf-8",
                dataType: "JSON",
                success: function (data, textStatus, jqXHR) {
                    console.log(data);
                    if (data.success == 1) {


                        $("#ModalLoadingSMS").css('display', 'none');
                        $("#ModalCancelDeclineRemarks").modal("hide");
                        $("#CancelDeclineId").val("");
                        $("#CancelDeclineMode").val("");
                        $("#CancelDeclineReason").val("");
                        swalAlertOnly("Success", data.message, "success");

                        //if()
                        $('#tableMorningAvailable').DataTable().clear().draw();
                        $('#tableMorningAvailable').DataTable().ajax.reload();
                        $('#tableAfternoonAvailable').DataTable().clear().draw();
                        $('#tableAfternoonAvailable').DataTable().ajax.reload();


                    } else {


                        $("#ModalLoadingSMS").css('display', 'none');
                        swalAlertOnly("Error", data.message, "error");
                    }
                }
        });

    }

</script>
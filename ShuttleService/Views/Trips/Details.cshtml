    function AssignReserve(_method) {
        //_method 1 -> assign, 2 -> remove

        var _link = "";
        var _reserve = "";
        var _groupClass = "";
        if (_method == 1) {
            _link = "@Url.Content("~/trips/reservePassengers")";
            _reserve = "Reserve";
            _groupClass = "checkBoxGroup";
        }
        else if (_method == 2) {
            _link = "@Url.Content("~/trips/removeReservePassengers")";
            _reserve = "Remove";
            _groupClass = "checkBoxGroupR";
        }

        var checkcounter = 0;
        var TransactionIds = "";
        $('.' + _groupClass).each(function () {
            if (this.checked) {
                checkcounter++;
                TransactionIds += this.value + ",";
            }
        });

        TransactionIds = TransactionIds.slice(0, -1);

        if (checkcounter <= 0) {
            swalAlertOnly("Error", "Please select data.", "error");
        }
        else if (checkcounter >= 1) {
            swal({
                title: "Are you sure?",
                text: "This will "+_reserve+" all the person(s) you selected",
                type: "warning",
                showCancelButton: true,
                confirmButtonColor: "#18a689",
                confirmButtonText: "Yes, " + _reserve+" it!",
                closeOnConfirm: false
            }, function () {
                if (_method == 1) {
                    $("#ModalLoadingSMS").modal('show');
                    $("#ModalLoadingSMS").css('display','block');
                } else {

                    $("#loading").modal("show");
                }

                    $.ajax({
                            type: "POST",
                            url: _link,
                        data: { "TransactionId": TransactionIds, "_id": $("#TripIdLoaded").val()},
                            //"contentType": "application/json; charset=utf-8",
                            dataType: "JSON",
                            success: function (data, textStatus, jqXHR) {

                                $("#lblRemaining").text(data.remainingAM);
                                $("#lblRemainingPM").text(data.remainingPM);
                                if (data.success == 1) {
                                    swalAlertOnly("Success", data.message, "success");
                                } else {
                                    swalAlertOnly("Error", data.message, "error");
                                }

                                $("#ModalLoadingSMS").css('display', 'none');

                                $(".TripLookup").removeClass("hidden");
                                $("#ReserveBtn").removeClass("hidden");


                                $('#tableMorning').DataTable().ajax.reload();
                                $('#tableAfternoon').DataTable().ajax.reload();
                                $('#tableMorningAvailable').DataTable().ajax.reload();
                                $('#tableAfternoonAvailable').DataTable().ajax.reload();
                                setTimeout(function () {
                                    $('#tableMorning').DataTable().columns.adjust().responsive.recalc();
                                    $('#tableAfternoon').DataTable().columns.adjust().responsive.recalc();
                                    $('#tableMorningAvailable').DataTable().columns.adjust().responsive.recalc();
                                    $('#tableAfternoonAvailable').DataTable().columns.adjust().responsive.recalc();
                                    $("#loading").modal("hide");
                                }, 1000);
                            }
                    });

            });

        }
    }


    function checkOther(_id, _this, _r) {
        if (_this.id != "") {
            var res = _this.id.split("_");

            if (_this.checked) {
                //alert(_id + 'checked');
                $('#checkselect' + _r + '2_' + res[1]).prop('checked', true);
                $('#checkselect' + _r + '3_' + res[1]).prop('checked', true);
            } else {
                $('#checkselect' + _r + '2_'  + res[1]).prop('checked', false);
                $('#checkselect' + _r + '3_'  + res[1]).prop('checked', false);
            }
        }


    }


@model ShuttleService.Models.Trip

@{
    ViewData["Title"] = "Trip";
}
<style>

    .clockpicker-popover {
        z-index: 99992 !important;
    }

    .select2-container {
        z-index: 99992 !important;
    }

    #createTrip {
        z-index: 99991 !important;
    }
</style>
<div class="wrapper wrapper-content row">
    <div class="col-md-4 pull-left">
        <h4>Shuttle Service Schedule - <red style="color:red">@ViewBag.dtimestamp</red></h4>
    </div>

    <div class="col-md-8 ">
        <div class="btn-group pull-right">
            @if (ViewBag.SMSLog <= 0)
            {
                <button type="button" class="btn btn-w-m btn-info smsbtn " onclick="SendSMSModal();">Send SMS Summary</button>
            }
            else
            {
                <button type="button" class="btn btn-w-m btn-info smsbtn " onclick="SendSMSModal();">Re-Send SMS Summary</button>
            }
            @if (ViewBag.OverAllApprover == 1)
            {
                <button type="button" class="btn btn-w-m btn-warning" onclick="OpenModalAddPassengerByPass();">Add New Passenger (Bypass)</button>
            }
            <button type="button" class="btn btn-w-m btn-primary" onclick="AddTrip();">Add New Trip</button>
            <button type="button" class="btn btn-w-m btn-success" onclick="ViewTrip();">View Trips</button>
            <button type="button" class="btn btn-w-m btn-danger " onclick="GoBack('@Url.Content("~/trips")')">Back</button>
        </div>
    </div>

    @*<div class="col-md-2">
            <button type="button" class="btn btn-w-m btn-primary btn-block" onclick="Reservation();">Add New Trip</button>
        </div>
        <div class="col-md-2">
            <button type="button" class="btn btn-w-m btn-success btn-block" onclick="Reservation();">View Trips</button>
        </div>
        <div class="col-md-2">
            <button type="button" class="btn btn-w-m btn-danger btn-block" onclick="GoBack('@Url.Content("~/shuttlepassengers")')">Back</button>
        </div>*@
</div>

<div class="modal fade" id="createTrip" tabindex="-1" role="dialog" data-backdrop="static" data-keyboard="false">
    <div class="modal-dialog modal-md" role="document">
        <div class="modal-content modal-col-red">
            <div class="modal-header" style=" padding: 10px 25px 5px 25px!important;border-style: none none solid none;">
                <h4 class="modal-title" id="ModalTitle" style="font-size: 15px;">Create Trip</h4>
            </div>
            <div class="modal-body">
                <form id="formTrip">
                    <div class="modal-body form-horizontal">

                        <div class="row hidden">
                            <div class="form-group">
                                <div class="col-sm-4">
                                    <label class="control-label"> Trip Type </label>
                                </div>
                                <div class="col-sm-8">

                                    <input class="form-control input-sm hidden" value="0" disabled id="TripId" name="TripId" />
                                    <input class="form-control input-sm hidden" value="@ViewBag.unixtimeFormatted" disabled id="ServiceDateTimeStamp" name="ServiceDateTimeStamp" />
                                    @*<select asp-for="ReservationTypeId" class="form-control" asp-items="ViewBag.ReservationTypeId"></select>*@
                                    <select id="ReservationTypeId" name="ReservationTypeId" class="form-control">
                                        <option value="1" selected>Shuttle Service</option>
                                    </select>
                                </div>
                            </div>
                        </div>
                        <div class="row">
                            <div class="form-group">
                                <div class="col-sm-4">
                                    <label class="control-label"> Time From </label>
                                </div>
                                <div class="col-sm-8">

                                    <div class="input-group clockpicker" data-autoclose="true">
                                        <input type="text" id="ServiceStartDate" name="ServiceStartDate" onchange="reInitVehicleDriver();clearOtherDate();" data-mask="99:99" class="form-control" value="00:00">
                                        <span class="input-group-addon">
                                            <span class="fa fa-clock-o"></span>
                                        </span>
                                    </div>

                                </div>
                            </div>
                        </div>
                        <div class="row">
                            <div class="form-group">
                                <div class="col-sm-4">
                                    <label class="control-label"> Time Until </label>
                                </div>
                                <div class="col-sm-8">
                                    <div class="input-group clockpicker" data-autoclose="true">
                                        <input type="text" id="ServiceEndDate" name="ServiceEndDate" onchange="reInitVehicleDriver();" data-mask="99:99" class="form-control" value="00:00">
                                        <span class="input-group-addon">
                                            <span class="fa fa-clock-o"></span>
                                        </span>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="row">
                            <div class="form-group">
                                <div class="col-sm-4">
                                    <label class="control-label"> Vehicle </label>
                                </div>
                                <div class="col-sm-8">
                                    <select id="VehicleListId" name="VehicleListId" class="form-control select2-vehicle"></select>
                                </div>
                            </div>
                        </div>
                        <div class="row">
                            <div class="form-group">
                                <div class="col-sm-4">
                                    <label class="control-label"> Capacity </label>
                                </div>
                                <div class="col-sm-8">
                                    <input class="form-control input-sm" readonly id="Capacity" name="Capacity" />
                                </div>
                            </div>
                        </div>

                        <div class="row">
                            <div class="form-group">
                                <div class="col-sm-4">
                                    <label class="control-label"> Driver </label>
                                </div>
                                <div class="col-sm-8">
                                    <select asp-for="DriverId" class="form-control select2-driver"></select>
                                </div>
                            </div>
                        </div>



                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <div class="loaded">
                    <button type="button" class="btn btn-success waves-effect" id="saveCreate" onclick="SaveTrip(1)">Save</button>
                    <button type="button" class="btn btn-success waves-effect hidden" id="saveUpdate" onclick="SaveTrip(2)">Save</button>
                    <button type="button" class="btn btn-danger waves-effect" data-dismiss="modal">Close</button>
                </div>
            </div>
        </div>
    </div>
</div>



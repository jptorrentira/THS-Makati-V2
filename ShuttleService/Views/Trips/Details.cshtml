    function SaveTrip(method) {
        var _start = parseInt($("#ServiceStartDate").val().replace(':', ''));
        var _end = parseInt($("#ServiceEndDate").val().replace(':', ''));

        if (_end <= _start) {

            swal({
                title: "Error",
                text: "Invalid Time",
                type: "error"
            });
        } else {


                            var methodTxt = "";
                            if (method == 1) {
                                methodTxt = "This will create a trip schedule";
                            }
                            else if (method == 2) {
                                methodTxt = "This will update this trip schedule";
                            }
                            else if (method == 3) {
                                methodTxt = "This will cancel this trip schedule";
                            }

                            if ($("#ReservationTypeId").val() == "" ||
                                $("#ServiceStartDate").val() == "" ||
                                $("#ServiceEndDate").val() == "" ||
                                $("#VehicleListId").val() == "" ||
                                $("#Capacity").val() == "" ||
                                $("#DriverId").val() == "") {

                                swalAlertOnly("Error", "Please complete all fields." , "error");
                            }
                            else {
                                swal({
                                    title: "Are you sure?",
                                    text: methodTxt,
                                    type: "warning",
                                    showCancelButton: true,
                                    confirmButtonColor: "#DD6B55",
                                    confirmButtonText: "Yes, Save it!",
                                    closeOnConfirm: false
                                }, function () {

                                    SubmitForm(method);

                                });
                            }
        }

    }

    function SubmitForm(method) {
                var l = $('#btnSave').ladda();
                l.ladda('start');
                $(".btn").attr("disabled", "disabled");
                $(".confirm").attr("disabled", "disabled");
                $(".cancel").attr("disabled", "disabled");
        var _url = "";
        if (method == 1) {
            _url = "@Url.Content("~/trips/create")";
        }
        else if (method == 2) {

            _url = "@Url.Content("~/trips/edit/")" + $("#TripId").val() + "?id="+$("#TripId").val()+"&";
        }
        else if (method == 3) {
            _url = "@Url.Content("~/trips/edit/")" + $("#TripId").val() + "?id="+$("#TripId").val()+"&";
        }

                    $.ajax({
                            type: "POST",
                            url: _url,
                            data: $("#formTrip").serialize() +"&ServiceDateTimeStamp=@ViewBag.unixtimeFormatted",
                            //"contentType": "application/json; charset=utf-8",
                            dataType: "JSON",
                            success: function (data, textStatus, jqXHR) {
                                console.log(data);
                                if (data.success == 1) {
                                    $("#createTrip").modal("hide");
                                    //if ($("#TripId").val() > 0) {

                                    //}

                                    $('#tableMorning').DataTable().ajax.reload();
                                    $('#tableAfternoon').DataTable().ajax.reload();


                                    swalAlertOnly("Success", data.message, "success");
                                    if ($("#TripId").val() == $("#TripIdLoaded").val()) {
                                        OpenThisTrip($("#TripId").val());
                                    }
                                } else {
                                    swalAlertOnly("Error", data.message, "error");
                                }
                                l.ladda('stop');
                                $(".btn").removeAttr("disabled");
                                $(".confirm").removeAttr("disabled");
                                $(".cancel").removeAttr("disabled");
                            }
                    });


                }

